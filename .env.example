# Copy this file to .env.local for local development.
# In Vercel, set this under Project Settings -> Environment Variables instead
# (see README.md for details) -- .env.local is never committed or deployed.

# Powers the two free models (visitors don't need their own key for these).
# Get one at https://openrouter.ai/keys, and set a spend/credit limit on it
# there -- this key is shared by every visitor to your deployed site.
OPENROUTER_API_KEY=
